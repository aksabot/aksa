{
	"name": "docs",
	"private": true,
	"type": "module",
	"scripts": {
		"sync": "bun run sync-docs.ts",
		"gen-llms": "bun run scripts/gen-llms.ts",
		"gen-search": "bun run scripts/gen-search-index.ts",
		"dev": "bun run sync && bun run gen-llms && bun run gen-search && bosia dev",
		"build": "bun run sync && bun run gen-llms && bun run gen-search && bosia build",
		"start": "bosia start",
		"check": "bosia sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"dependencies": {
		"@lucide/svelte": "^1.25.0",
		"bosia": "^0.8.12",
		"gray-matter": "^4.0.3",
		"marked": "^18.0.6",
		"shiki": "^4.3.1",
		"svelte": "^5.56.3",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"prettier": "^3.3.0",
		"prettier-plugin-svelte": "^3.2.0",
		"svelte-check": "^4.4.8",
		"typescript": "^5"
	}
}
